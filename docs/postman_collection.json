{
  "info": {
    "name": "Project Management API",
    "_postman_id": "94d4cc85-80a5-4f0c-b11a-3c72f56d5f1a",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api/v1" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@techbrein.local\",\n  \"password\": \"Admin@123\"\n}"
        }
      }
    },
    {
      "name": "Users - Create",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/users",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"John Developer\",\n  \"email\": \"john@example.com\",\n  \"password\": \"Password@123\",\n  \"role\": \"developer\"\n}"
        }
      }
    },
    {
      "name": "Users - List",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/users?page=1&page_size=10"
      }
    },
    {
      "name": "Projects - Create",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/projects",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Internal CRM\",\n  \"description\": \"Project to revamp internal CRM workflows\"\n}"
        }
      }
    },
    {
      "name": "Projects - List",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/projects?page=1&page_size=10"
      }
    },
    {
      "name": "Projects - Update",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/projects/1",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"description\": \"Updated description\"\n}"
        }
      }
    },
    {
      "name": "Projects - Delete",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/projects/1"
      }
    },
    {
      "name": "Tasks - Create",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/tasks",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Set up project board\",\n  \"description\": \"Create kanban board and backlog\",\n  \"project_id\": 1,\n  \"assigned_to\": 2,\n  \"due_date\": \"2026-04-10\"\n}"
        }
      }
    },
    {
      "name": "Tasks - Assign",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/tasks/1/assign",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"assigned_to\": 2\n}"
        }
      }
    },
    {
      "name": "Tasks - Update Status",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/tasks/1/status",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"in_progress\"\n}"
        }
      }
    },
    {
      "name": "Tasks - List",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/tasks?page=1&page_size=10&project_id=1&status=todo&assigned_to=2"
      }
    }
  ]
}
